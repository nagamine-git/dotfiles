! keycode 43 (Colemak: h/H): Alt+h = Left
! 元の割り当て (KeySym1-4) を維持し、KeySym5 に Left を設定
keycode 43 = h H h H Left NoSymbol

! keycode 44 (Colemak: n/N): Alt+n = Up
! 元の割り当て (KeySym1-4) を維持し、KeySym5 に Up を設定
keycode 44 = n N n N Up NoSymbol

! keycode 45 (Colemak: e/E): Alt+e = Down
! 元の割り当て (KeySym1-4) を維持し、KeySym5 に Down を設定
keycode 45 = e E e E Down NoSymbol

! keycode 46 (Colemak: i/I): Alt+i = Right
! 元の割り当て (KeySym1-4) を維持し、KeySym5 に Right を設定
keycode 46 = i I i I Right NoSymbol
