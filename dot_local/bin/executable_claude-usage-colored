#!/bin/bash
# claude-usage wrapper with color highlighting based on utilization

output=$(claude-usage 2>/dev/null)
[ -z "$output" ] && exit 0

# 5h / 7d utilization を抽出し、高い方で状態判定
pct5=$(echo "$output" | grep -oP '5h:\K[0-9]+')
pct7=$(echo "$output" | grep -oP '7d:\K[0-9]+')
max=$(printf '%s\n%s\n' "${pct5:-0}" "${pct7:-0}" | sort -n | tail -1)

if [ -z "$pct5" ] && [ -z "$pct7" ]; then
    echo "$output"
    exit 0
fi

# powerline segment（accent背景）上で読みやすくするため fg=黒固定
# 70%未満なら細字、以上ならbold。警告域は bg 色でシグナル
if [ "$max" -ge 90 ]; then
    echo "#[fg=#161719,bg=#b84d51,bold]$output#[default]"
elif [ "$max" -ge 75 ]; then
    echo "#[fg=#161719,bg=#e4b55e,bold]$output#[default]"
elif [ "$max" -ge 70 ]; then
    echo "#[fg=#161719,bold]$output#[default]"
else
    echo "#[fg=#161719,nobold]$output#[default]"
fi
