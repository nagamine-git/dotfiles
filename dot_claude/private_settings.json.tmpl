{
  "env": {
    "PLAYWRIGHT_MCP_EXECUTABLE_PATH": "{{ if eq .chezmoi.os "darwin" }}/Applications/Google Chrome.app/Contents/MacOS/Google Chrome{{ else }}/opt/google/chrome/google-chrome{{ end }}"
  },
  "permissions": {
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push * --force*)",
      "Bash(git push * -f*)",
      "Bash(git reset --hard origin/main*)",
      "Bash(git reset --hard origin/master*)",
      "Bash(git rebase * --root*)",
      "Bash(gh repo create*)",
      "Bash(gh repo delete*)",
      "Bash(npm publish*)",
      "Bash(yarn publish*)",
      "Bash(pnpm publish*)",
      "Bash(cargo publish*)"
    ],
    "defaultMode": "auto"
  },
{{- if eq .chezmoi.os "darwin" }}
  "model": "claude-opus-4-8",
{{- end }}
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.local/bin/claude-usage --refresh >/dev/null 2>&1"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.local/bin/claude-notify stop \"作業が完了しました\" >/dev/null 2>&1"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "freee-mcp@freee-mcp-marketplace": true
  },
  "extraKnownMarketplaces": {
    "freee-mcp-marketplace": {
      "source": {
        "source": "github",
        "repo": "freee/freee-mcp"
      }
    }
  },
  "language": "japanese",
  "effortLevel": "high",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--browser",
        "chromium",
        "--executable-path",
        "{{ if eq .chezmoi.os "darwin" }}/Applications/Google Chrome.app/Contents/MacOS/Google Chrome{{ else }}/opt/google/chrome/google-chrome{{ end }}"
      ]
    },
    "zeed-browser": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--browserUrl",
        "http://127.0.0.1:9222"
      ]
    },
    "slack": {
      "type": "http",
      "url": "https://mcp.slack.com/mcp",
      "oauth": {
        "clientId": "1601185624273.8899143856786",
        "callbackPort": 3118
      }
    }
  },
  "allowCommandExecution": true,
  "autoExecuteCommands": true
}
