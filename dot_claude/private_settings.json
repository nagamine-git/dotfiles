{
  "env": {
    "PLAYWRIGHT_MCP_EXECUTABLE_PATH": "/opt/google/chrome/google-chrome"
  },
  "permissions": {
    "defaultMode": "auto",
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push * --force*)",
      "Bash(git push * -f*)",
      "Bash(git reset --hard origin/main*)",
      "Bash(git reset --hard origin/master*)",
      "Bash(git rebase * --root*)",
      "Bash(gh repo create*)",
      "Bash(gh repo delete*)",
      "Bash(npm publish*)",
      "Bash(yarn publish*)",
      "Bash(pnpm publish*)",
      "Bash(cargo publish*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/tsuyoshi/.local/bin/claude-usage --refresh >/dev/null 2>&1"
          },
          {
            "type": "command",
            "command": "/home/tsuyoshi/.local/bin/claude-notify stop \"作業が完了しました\" >/dev/null 2>&1"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "slack@claude-plugins-official": true
  },
  "language": "japanese",
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--browser",
        "chromium",
        "--executable-path",
        "/opt/google/chrome/google-chrome"
      ]
    }
  },
  "allowCommandExecution": true,
  "autoExecuteCommands": true
}
