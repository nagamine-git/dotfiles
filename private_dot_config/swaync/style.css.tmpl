{{- $c := .theme.colors -}}
{{- $f := .theme.fonts -}}
/* 基本スタイル */
* {
  font-family: '{{ $f.ui }}', '{{ $f.mono }}', sans-serif;
  background-color: transparent;
}

.notification-row {
  outline: none;
}

.notification-row:focus,
.notification-row:hover {
  background: rgba({{ $c.primary.rgb }}, 0.18);
}

.notification {
  background: rgba({{ $c.bg_dark.rgb }}, 0.97);
  padding: 12px;
  margin: 6px;
  border-radius: 12px;
  border: 1px solid rgba({{ $c.surface.rgb }}, 0.7);
  font-size: 10pt;
}

.notification-content {
  background: transparent;
  padding: 0;
  margin: 0;
}

.close-button {
  background: rgba({{ $c.surface.rgb }}, 0.5);
  color: rgba({{ $c.text.rgb }}, 1);
  text-shadow: none;
  padding: 0;
  border-radius: 8px;
  margin-top: 8px;
  margin-right: 8px;
}

.close-button:hover {
  background: rgba({{ $c.primary.rgb }}, 0.6);
}

.notification-default-action,
.notification-action {
  background: rgba({{ $c.bg_medium.rgb }}, 0.92);
  color: rgba({{ $c.text.rgb }}, 1);
  margin: 4px;
  border-radius: 6px;
  padding: 4px 8px;
}

.notification-default-action:hover,
.notification-action:hover {
  background: rgba({{ $c.surface.rgb }}, 0.92);
}

.notification-default-action {
  background: rgba({{ $c.bg_dark.rgb }}, 0.97);
}

.notification-default-action:hover {
  background: rgba({{ $c.bg_medium.rgb }}, 0.92);
}

.summary {
  font-size: 10pt;
  font-weight: bold;
  background: transparent;
  color: rgba({{ $c.text.rgb }}, 1);
  text-shadow: none;
}

.time {
  font-size: 9pt;
  font-weight: normal;
  background: transparent;
  color: rgba({{ $c.text.rgb }}, 0.7);
  text-shadow: none;
  margin-right: 16px;
}

.body {
  font-size: 10pt;
  font-weight: normal;
  background: transparent;
  color: rgba({{ $c.text.rgb }}, 0.9);
  text-shadow: none;
}

.control-center {
  background: rgba({{ $c.bg_dark.rgb }}, 0.97);
  border: 1px solid rgba({{ $c.surface.rgb }}, 0.7);
  border-radius: 12px;
  margin: 6px;
}

.control-center-list {
  background: transparent;
}

.control-center-list-placeholder {
  opacity: 0.5;
  margin: 20px;
}

.floating-notifications {
  background: transparent;
}

.blank-window {
  background: alpha(black, 0.35);
}

.widget-title {
  color: rgba({{ $c.text.rgb }}, 1);
  background: rgba({{ $c.bg_medium.rgb }}, 0.92);
  padding: 8px 12px;
  margin: 12px;
  border-radius: 8px;
  font-size: 11pt;
  font-weight: bold;
}

.widget-title > button {
  font-size: 10pt;
  color: rgba({{ $c.text.rgb }}, 1);
  background: rgba({{ $c.surface.rgb }}, 0.92);
  border: 1px solid rgba({{ $c.primary.rgb }}, 0.4);
  border-radius: 6px;
  padding: 4px 8px;
}

.widget-title > button:hover {
  background: rgba({{ $c.primary.rgb }}, 0.92);
}

.widget-dnd {
  color: rgba({{ $c.text.rgb }}, 1);
  background: rgba({{ $c.bg_medium.rgb }}, 0.92);
  padding: 8px 12px;
  margin: 12px;
  border-radius: 8px;
  font-size: 10pt;
}

.widget-dnd > switch {
  border-radius: 8px;
  background: rgba({{ $c.surface.rgb }}, 0.92);
}

.widget-dnd > switch:checked {
  background: rgba({{ $c.accent.rgb }}, 0.9);
}

.urgency-low {
  background: rgba({{ $c.bg_dark.rgb }}, 0.97);
  border: 1px solid rgba({{ $c.text_dim.rgb }}, 0.5);
}

.urgency-normal {
  background: rgba({{ $c.bg_dark.rgb }}, 0.97);
  border: 1px solid rgba({{ $c.primary.rgb }}, 0.45);
}

.urgency-critical {
  background: rgba({{ $c.bg_medium.rgb }}, 0.98);
  border: 1px solid rgba({{ $c.error.rgb }}, 0.98);
}

/* 通知タイトル */
.notification .notification-title {
  font-weight: bold;
  margin-bottom: 4px;
}

/* 通知本文 */
.notification .notification-body {
  opacity: 0.9;
}

/* 通知アイコン */
.notification .notification-icon {
  margin-right: 8px;
}

/* プログレスバー */
.notification .notification-progress {
  background-color: rgba(128, 128, 128, 0.4);
  border-radius: 4px;
  height: 4px;
  margin-top: 8px;
}

.notification .notification-progress .notification-progress-bar {
  background-color: rgba(128, 128, 128, 1);
  border-radius: 4px;
  height: 100%;
}

/* 空の通知リスト */
.control-center .control-center-list .placeholder {
  opacity: 0.7;
  font-style: italic;
  margin: 20px;
  text-align: center;
}
