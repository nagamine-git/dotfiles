{{- $c := .theme.colors -}}
{{- if eq .chezmoi.os "darwin" }}{{ $c = .theme.colors_darwin }}{{ end -}}
/* 中央テーマ(.theme.colors)から GTK3 のベース色を上書きし、ghostty/tmux と配色を一致させる。
   ベーステーマ(Adwaita-dark)のウィジェット形状は活かしつつ色だけ差し替える方式。
   ※ この @define-color は全 GTK3 アプリに効く（thunar 含む / 一貫テーミング）。 */
@define-color theme_bg_color           #{{ $c.bg_medium.hex }};
@define-color theme_base_color         #{{ $c.bg_dark.hex }};
@define-color theme_fg_color           #{{ $c.text.hex }};
@define-color theme_text_color         #{{ $c.text.hex }};
@define-color theme_selected_bg_color  #{{ $c.primary.hex }};
@define-color theme_selected_fg_color  #{{ $c.bg_dark.hex }};
@define-color insensitive_bg_color     #{{ $c.bg_light.hex }};
@define-color insensitive_fg_color     #{{ $c.text_dim.hex }};
@define-color theme_unfocused_bg_color #{{ $c.bg_medium.hex }};
@define-color theme_unfocused_fg_color #{{ $c.text_dim.hex }};
@define-color borders                  #{{ $c.surface.hex }};
@define-color warning_color            #{{ $c.warning.hex }};
@define-color error_color              #{{ $c.error.hex }};
@define-color success_color            #{{ $c.success.hex }};

/* GTKスクロールバーのカスタマイズ */

/* スクロールバーを完全に非表示 */
scrollbar {
  opacity: 0;
  min-width: 0;
  min-height: 0;
  background: transparent;
}

scrollbar * {
  opacity: 0;
  min-width: 0;
  min-height: 0;
  background: transparent;
}

/* Wofi特有のスクロールバー制御 */
#wofi scrollbar,
.wofi scrollbar {
  opacity: 0;
  background: transparent;
}
