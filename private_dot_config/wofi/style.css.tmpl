{{- $c := .theme.colors -}}
{{- $f := .theme.fonts -}}
* {
  font-family: "{{ $f.ui }}", sans-serif;
  font-size: 13px;
  scrollbar-width: none; /* Firefox */
}

window {
  margin: 0px;
  background-color: rgba({{ $c.bg_dark.rgb }}, 0.92);
  border-radius: 12px;
  border: 1px solid rgba({{ $c.primary.rgb }}, 0.25);
}

#input {
  margin: 8px;
  padding: 8px 12px;
  border-radius: 12px;
  border: none;
  color: #{{ $c.text.hex }};
  background-color: rgba({{ $c.bg_medium.rgb }}, 0.85);
  transition: background-color 0.2s ease;
}

#input:focus {
  border: none;
  outline: none;
  background-color: rgba({{ $c.bg_light.rgb }}, 0.9);
}

#inner-box {
  margin: 4px;
  padding: 8px;
  border-radius: 8px;
}

#outer-box {
  margin: 4px;
  padding: 6px;
  border: none;
}

#entry {
  padding: 8px 12px;
  border-radius: 8px;
  transition: background-color 0.2s ease;
}

#entry:selected {
  background-color: rgba({{ $c.primary.rgb }}, 0.3);
}

#text {
  color: #{{ $c.text.hex }};
  margin-left: 8px;
}

#text:selected {
  color: #{{ $c.accent.hex }};
  font-weight: bold;
}

#img {
  margin-right: 8px;
}

#scroll {
  margin: 4px;
}

/* スクロールバー非表示 */
scrollbar {
  all: unset;
}
