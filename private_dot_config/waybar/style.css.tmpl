{{- $c := .theme.colors -}}
{{- $f := .theme.fonts -}}
* {
  margin: 0;
  padding: 0;
  font-size: 14px;
  color: #{{ $c.text.hex }};
  background-color: transparent;
}

#waybar {
  padding: 4px;
  background-color: rgba({{ $c.bg_dark.rgb }}, 0.88);
  border-radius: 8px;
}

/* Common module styling */
#cpu, #memory, #disk, #temperature,
#network, #battery, #pulseaudio,
#clock, #tray, #custom-power, #custom-disk, #custom-pomodoro, #custom-gpu {
  padding: 0 8px;
  margin: 0 3px;
  transition: background-color 0.2s ease;
}

/* Battery states */
.warning {
  color: #{{ $c.warning.hex }};
  font-weight: bold;
}

.critical {
  color: #{{ $c.error.hex }};
  font-weight: bold;
}

/* Workspaces */
#workspaces {
  background-color: transparent;
  padding: 0 8px;
}

#workspaces button {
  color: #{{ $c.text_dim.hex }};
  background: transparent;
  margin: 0;
  font-size: 14px;
  transition: color 0.2s ease;
  font-family: "{{ $f.mono }}", monospace;
}

#workspaces button.active,
#workspaces button.focused {
  color: #{{ $c.accent.hex }};
  font-weight: bold;
}

/* Context menu styling */
tooltip {
  background-color: rgba({{ $c.bg_medium.rgb }}, 0.96);
  border-radius: 6px;
  border: 1px solid rgba({{ $c.primary.rgb }}, 0.8);
}

tooltip label {
  color: #{{ $c.text.hex }};
  padding: 6px 12px;
}

menu {
  background-color: rgba({{ $c.bg_medium.rgb }}, 0.96);
  border-radius: 6px;
}
menuitem {
  padding: 8px 12px;
  margin: 2px 0;
}
menuitem:hover {
  background-color: rgba({{ $c.surface.rgb }}, 1);
}

#custom-pomodoro.warning { color: #{{ $c.error.hex }}; }
#custom-pomodoro.break   { color: #{{ $c.success.hex }}; }
#custom-pomodoro { font-family: "{{ $f.mono }}", monospace; }

/* Blink animation used by pomodoro script */
.blink {
  animation: blink 1s steps(2, start) infinite;
}
@keyframes blink {
  to { color: transparent; }
}
