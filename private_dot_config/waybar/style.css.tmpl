{{- $c := .theme.colors -}}
{{- if eq .chezmoi.hostname "fp7-e14" -}}{{- $c = .theme.colors_catppuccin -}}{{- end -}}
{{- $f := .theme.fonts -}}
/* 以下3色は waybar-auto-theme.sh が壁紙上部の輝度で書き換える(既定=dark)。
   明るい壁紙 → 黒文字/白バー、暗い壁紙 → 白文字/黒バー に自動切替される。 */
@define-color wbfg #{{ $c.text.hex }};
@define-color wbbg rgba({{ $c.bg_dark.rgb }}, 0.85);
@define-color wbsh rgba(0, 0, 0, 0.7);

* {
  margin: 0;
  padding: 0;
  font-size: 14px;
  /* 全モジュールに Nerd Font 入り等幅を適用。未指定だと GTK 既定フォント →
     アイコン(PUA)が Noto CJK にフォールバックして漢字化するため必須。 */
  font-family: "{{ $f.mono }}", monospace;
  color: @wbfg;
  background-color: transparent;
  /* どの壁紙でも文字が埋もれないよう影で輪郭を確保 (色も自動切替) */
  text-shadow: 0 1px 2px @wbsh;
}

#waybar {
  padding: 4px;
  margin: 2px 0 0 0;
  background-color: @wbbg;
  border-radius: 8px;
}

/* Common module styling */
#cpu, #memory, #disk, #temperature,
#network, #battery, #pulseaudio,
#clock, #tray, #custom-power, #custom-disk, #custom-pomodoro, #custom-gpu {
  padding: 0 8px;
  margin: 0 3px;
  transition: background-color 0.2s ease;
}

/* Battery states */
.warning {
  color: #{{ $c.warning.hex }};
  font-weight: bold;
}

.critical {
  color: #{{ $c.error.hex }};
  font-weight: bold;
}

/* Workspaces */
#workspaces {
  background-color: transparent;
  padding: 0 8px;
}

#workspaces button {
  color: #{{ $c.text_dim.hex }};
  background: transparent;
  margin: 0;
  font-size: 14px;
  transition: color 0.2s ease;
  font-family: "{{ $f.mono }}", monospace;
}

#workspaces button.active,
#workspaces button.focused {
  color: #{{ $c.accent.hex }};
  font-weight: bold;
}

/* Context menu styling */
tooltip {
  background-color: rgba({{ $c.bg_medium.rgb }}, 0.96);
  border-radius: 6px;
  border: 1px solid rgba({{ $c.primary.rgb }}, 0.8);
}

tooltip label {
  color: #{{ $c.text.hex }};
  padding: 6px 12px;
}

menu {
  background-color: rgba({{ $c.bg_medium.rgb }}, 0.96);
  border-radius: 6px;
}
menuitem {
  padding: 8px 12px;
  margin: 2px 0;
}
menuitem:hover {
  background-color: rgba({{ $c.surface.rgb }}, 1);
}

#custom-pomodoro.warning { color: #{{ $c.error.hex }}; }
#custom-pomodoro.break   { color: #{{ $c.success.hex }}; }
#custom-pomodoro { font-family: "{{ $f.mono }}", monospace; }

#custom-tailscale.direct { color: #{{ $c.text_dim.hex }}; }
#custom-tailscale.exit   { color: #{{ $c.warning_alt.hex }}; font-weight: bold; }
#custom-tailscale.off    { color: #{{ $c.error.hex }}; }

/* Blink animation used by pomodoro script */
.blink {
  animation: blink 1s steps(2, start) infinite;
}
@keyframes blink {
  to { color: transparent; }
}
