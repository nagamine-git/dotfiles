    "interval": 5,
    "format": "у°”Џ {icon}",
    "format-icons": ["вЎЂ", "вЎЂ", "вЎЂ", "вЈЂ", "вЈ„", "вЈ¤", "вЈ¦", "вЈ¶", "вЈ·", "вЈї"],
    "critical-threshold": 80,
    "tooltip": true,
    "tooltip-format": "CPU Temperature: {temperatureC}В°C"
  },

  "network": {
    "format-wifi": "у°¤Ё {essid}",
    "format-ethernet": "у°€Ђ",
