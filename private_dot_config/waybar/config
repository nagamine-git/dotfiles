{
  "layer": "top",
  "position": "top",
  "height": 32,
  "margin": "4 4 0 4",
  "spacing": 4,
  "radius": 8,
  "font": "'Roboto + Noto Sans JP', 'FirgeNerd Console', sans-serif",

  "modules-left": ["hyprland/workspaces", "hyprland/window"],
  "modules-center": ["clock", "custom/pomodoro", "custom/toggl"],
  "modules-right": ["tray", "temperature", "cpu", "custom/gpu", "memory", "custom/disk", "network", "pulseaudio"],

"custom/pomodoro": {
  "exec": "~/.config/waybar/scripts/pomodoro.sh",
  "interval": 1,
  "return-type": "json",
  "tooltip": true
},

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "в—Џ",
      "default": "в—‹"
    },
    "on-click": "hyprctl dispatch workspace {name}",
  },

  "hyprland/window": {
    "max-length": 40
  },

  "custom/gpu": {
    "exec": "~/.config/waybar/scripts/gpu_status.sh",
    "interval": 3,
    "return-type": "json",
    "tooltip": true
  },

  "clock": {
    "format": "{:%y-%m-%d %a %H:%M:%S}",
    "interval": 1,
    "locale": "C",
    "timezone": "Asia/Tokyo",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months":   "<span color='#dddddd'><b>{}</b></span>",
        "weekdays": "<span color='#cccccc'><b>{}</b></span>",
        "weeks":    "<span color='#bbbbbb'><b>W{}</b></span>",
        "days":     "<span color='#eeeeee'><b>{}</b></span>",
        "today":    "<span color='#ffffff'><b><u>{}</u></b></span>"
      }
    },

    "actions": {
      "on-click-right": "mode",
      "on-scroll-up":   "shift_up",
      "on-scroll-down": "shift_down"
    }
  },

  "cpu": {
    "interval": 3,
    "format": "п’ј {icon}",
    "format-icons": ["вЎЂ", "вЈЂ", "вЈ„", "вЈ¤", "вЈ¦", "вЈ¶", "вЈ·", "вЈї"],
    "states": {
      "warning": 80,
      "critical": 95
    },
    "tooltip": true
  },

  "memory": {
    "interval": 5,
    "format": "у°†» {icon}",
    "format-icons": ["вЎЂ", "вЈЂ", "вЈ„", "вЈ¤", "вЈ¦", "вЈ¶", "вЈ·", "вЈї"],
    "states": {
      "warning": 80,
      "critical": 90
    },
    "tooltip": true
  },

  "custom/disk": {
    "format": "у°‹Љ {}",
