# #######################################################################################
# Hyprland Configuration File
# #######################################################################################

# This file has been customized from the autogenerated configuration.
# For more information, see: https://wiki.hyprland.org/Configuring/
# Complete list of settings/options: https://wiki.hyprland.org/

################
### MONITORS ###
################

source = ~/.config/hypr/monitors.conf
source = ~/.config/hypr/workspaces.conf

###################
### MY PROGRAMS ###
###################

{{/*
  端末を GPU 能力で自動選択 (apply 時に検出)。
  - ディスクリート GPU あり (NVIDIA / Radeon RX / Navi / Arc) → ghostty (GPUアクセラ快適)
  - 内蔵GPUのみ / VM / 検出失敗時の弱シグナル → foot (純CPUレンダで安定)
  手動強制: 環境変数 CHEZMOI_TERMINAL=foot|ghostty で上書き。
  lspci が空(検出不能)のときは ghostty を維持し、誤って foot へ格下げしない。
*/ -}}
{{/* systemd-detect-virt は非仮想でも stdout に "none" を出しつつ exit 1 を返す。
     `|| echo none` だと none が二重出力され $virt="none\nnone" となり、ne 判定が
     誤って真 → GPU 有無に関わらず foot へ格下げされる。stdout のみを1値で取る。 */ -}}
{{- $virt := output "sh" "-c" "v=$(systemd-detect-virt 2>/dev/null); echo \"${v:-none}\"" | trim -}}
{{- $disc := output "sh" "-c" "vga=$(lspci 2>/dev/null | grep -iE 'VGA|3D|Display'); if [ -z \"$vga\" ]; then echo unknown; elif printf '%s' \"$vga\" | grep -iqE 'NVIDIA|Radeon RX|Navi [0-9]|Arc [AB][0-9]'; then echo yes; else echo no; fi" | trim -}}
{{- $terminal := "ghostty" -}}
{{- if or (ne $virt "none") (eq $disc "no") -}}{{- $terminal = "foot" -}}{{- end -}}
{{- $terminal = env "CHEZMOI_TERMINAL" | default $terminal -}}
$terminal = {{ $terminal }}
$fileManager = thunar
$menu = wofi --show drun
$browser = zeed

#################
### AUTOSTART ###
#################

exec-once = fcitx5 -d --replace
exec-once = 1password --silent &
exec-once = hyprvoice serve &
# 壁紙の上部輝度で waybar を明/暗テーマに切替えてから waybar を起動 (; で順序保証、
# テーマ失敗時も waybar は立つ)。壁紙変更時は waybar-auto-theme.sh を手動再実行。
exec-once = ~/.local/bin/waybar-auto-theme.sh; waybar &
exec-once = ~/.local/bin/swaync_launcher.sh &
exec-once = swayosd-server &
exec-once = hyprpaper &
exec-once = mkdir -p /tmp/hypr/$USER
exec-once = cliphist &
exec-once = wl-paste --type text --watch cliphist store &
exec-once = wl-paste --type image --watch cliphist store &
exec-once = autokey-gtk --hide &
# hypridle は dpms off を撃った直後に落ちると on-resume が二度と発火せず
# 画面が黒いまま戻らなくなる (2026-05-29 調査)。exec-once は自動復活しないため
# self-healing ループで起動し、落ちても 3 秒後に復活させる。
# fp7-e14 は常時ホスト (lid 閉じ・headless) なので hypridle を起動しない =
# 画面ロック/dpms/idle-sleep を無効化 (suspend は systemd target mask で別途封印)。
{{- if ne .chezmoi.hostname "fp7-e14" }}
exec-once = bash -c 'while true; do hypridle; logger -t hypridle "respawned (exit=$?)"; sleep 3; done' &
{{- end }}
# polkit 認証エージェント: 1Password の system-auth アンロック / SSH署名承認ダイアログに必須。
# 不在だと 1Password agent が署名を即拒否し、SSH鍵認証が "agent refused operation" で全滅する。
exec-once = /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 &
exec-once = sudo keyd &
exec-once = systemctl --user start darkman.service &
exec-once = systemctl --user start sunshine.service &
exec-once = ~/.local/bin/hypr_auto_perfmonitor.sh start &
# VRR は 4K@120Hz HDMI でパネルが黒落ちするため、起動時にモニタへ vrr,0 を明示再適用する
# (misc:vrr=0 は source=monitors.conf より後に評価されモニタ初期化時に効かないため)。
exec-once = ~/.local/bin/hypr-vrr-off.sh &
exec-once = ~/.local/bin/claude-usage-notify &
exec-once = ~/.local/bin/droidcam.sh &
exec-once = ~/.local/bin/executable_sleep_backup.sh &
exec-once = way-thumbsense --exclude-left=10 --exclude-right=10 & 

# Float these instances on special workspaces
windowrule {
  name = scratchterm-float
  float = 1
  match:class = ^(scratchterm)$
  match:workspace = name:special:term
}

windowrule {
  name = notes-float
  float = 1
  match:class = ^(notes)$
  match:workspace = name:special:notes
}

windowrule = border_color rgb({{ upper $c.warning.hex }}) rgb({{ upper $c.warning_alt.hex }}), match:fullscreen 1

windowrule {
  name = magic-workspace-border
  border_color = rgb({{ upper $c.accent.hex }}) rgb({{ upper $c.primary.hex }})
  match:workspace = name:special:magic
}

windowrule {
  name = term-workspace-border
  border_color = rgb({{ upper $c.accent.hex }}) rgb({{ upper $c.primary.hex }})
  match:workspace = name:special:term
}

windowrule {
  name = notes-workspace-border
  border_color = rgb({{ upper $c.accent.hex }}) rgb({{ upper $c.primary.hex }})
  match:workspace = name:special:notes
}

windowrule {
  name = desktop-workspace-border
  border_color = rgb({{ upper $c.accent.hex }}) rgb({{ upper $c.primary.hex }})
  match:workspace = name:special:desktop
}

#############################
### ENVIRONMENT VARIABLES ###
#############################

# Locale settings
env = LANG,ja_JP.UTF-8
env = LC_ALL,ja_JP.UTF-8

# XWayland keyboard layout fix
env = XKB_DEFAULT_LAYOUT,us
env = XKB_DEFAULT_VARIANT,colemak

# Cursor settings
env = XCURSOR_SIZE,24
env = HYPRCURSOR_SIZE,24

# セッション情報（Hyprlandが直接管理する必要がある）
env = XDG_CURRENT_DESKTOP,Hyprland
env = XDG_SESSION_TYPE,wayland
env = XDG_SESSION_DESKTOP,Hyprland

# Input method settings (fcitx5)
env = GTK_IM_MODULE,fcitx
env = QT_IM_MODULE,fcitx
env = XMODIFIERS,@im=fcitx

# Wayland support
env = GDK_BACKEND,wayland,x11,*
env = QT_QPA_PLATFORM,wayland;xcb
env = SDL_VIDEODRIVER,wayland
env = CLUTTER_BACKEND,wayland

# Electron apps Wayland support
env = ELECTRON_OZONE_PLATFORM,wayland
env = ELECTRON_OZONE_PLATFORM_HINT,wayland
env = OZONE_PLATFORM,wayland
env = DISABLE_GPU_SANDBOX,1
env = ELECTRON_DISABLE_GPU_SANDBOX,1

# Browser settings
env = MOZ_ENABLE_WAYLAND,1

# Application settings
env = BROWSER,zeed
env = QT_QPA_PLATFORMTHEME,qt6ct

# GTK settings
env = GTK_OVERLAY_SCROLLING,0

# Wayland-specific optimizations
env = QT_WAYLAND_DISABLE_WINDOWDECORATION,1
env = QT_AUTO_SCREEN_SCALE_FACTOR,1
env = QT_SCALE_FACTOR,1

# Java AWT fix
env = _JAVA_AWT_WM_NONREPARENTING,1


# GPU crash prevention - disable hardware cursors
env = WLR_NO_HARDWARE_CURSORS,1
env = HYPR_IGNORE_GPU_RESETS,1

#######################
### XWAYLAND CONFIG ###
#######################

xwayland {
    force_zero_scaling = true
    use_nearest_neighbor = true
}

#####################
### LOOK AND FEEL ###
#####################

general {
    gaps_in = 5
    gaps_out = 5
    border_size = 1
    col.inactive_border = rgba({{ $c.surface.hex }}66)
    col.active_border = rgba({{ $c.primary.hex }}cc)
    resize_on_border = true
    allow_tearing = true
    layout = dwindle
}

decoration {
    rounding = 8
    rounding_power = 6
    active_opacity = 1.0
    inactive_opacity = 0.8

    shadow {
        enabled = true
        range = 8
        render_power = 2
        color = rgba(00000040)
    }

    blur {
        enabled = true
        size = 10
        passes = 4
        new_optimizations = true
        xray = true
        noise = 0
        contrast = 1.0
        brightness = 1.0
        vibrancy = 0.1696
    }
}

group {
    groupbar {
        enabled = true
        font_family = {{ $f.ui }}
        font_size = 11
        gradients = true
        height = 20
        priority = 4
        render_titles = true
        scrolling = true
        text_color = rgba({{ $c.text.hex }}ff)
        indicator_gap = 2
        indicator_height = 0
        rounding = 6
        gradient_rounding = 6
        round_only_edges = true
        gradient_round_only_edges = true
        gaps_in = 2
        gaps_out = 2
        keep_upper_gap = false
        col.active = rgba({{ $c.bg_medium.hex }}ff)
        col.inactive = rgba({{ $c.bg_light.hex }}cc)
        col.locked_active = rgba({{ $c.primary.hex }}ff)
        col.locked_inactive = rgba({{ $c.surface.hex }}cc)
    }
    
    col.border_active = rgba(00000000)
    col.border_inactive = rgba(00000000)
    col.border_locked_active = rgba(00000000)
    col.border_locked_inactive = rgba(00000000)
}

animations {
    enabled = true
    animation = global, 1, 0.175, default
}

######################
### WINDOW RULES ###
######################

# Input method rules
windowrule {
  name = fcitx-nofocus
  no_initial_focus = 1
  match:class = ^(fcitx)$
  match:title = ^(fcitx)$
}

# Fix some dragging issues with XWayland
windowrule {
  name = xwayland-fix
  no_initial_focus = 1
  match:xwayland = 1
}

# Layer rules: blur for waybar
layerrule = blur on, match:namespace waybar
layerrule = ignore_alpha 0.2, match:namespace waybar

#######################
### LAYOUT SETTINGS ###
#######################

dwindle {
    preserve_split = true
}

master {
    new_status = master
}

misc {
    disable_hyprland_logo = true
    disable_splash_rendering = true
    vrr = 0
    mouse_move_enables_dpms = true
    key_press_enables_dpms = true
    always_follow_on_dnd = true
    layers_hog_keyboard_focus = true
    animate_manual_resizes = false
    enable_swallow = true
    swallow_regex = ^(Alacritty|kitty|ghostty|footclient)$
    # ロックスクリーンが死んだ場合に同じ session-lock を新しい hyprlock で
    # 復元できるようにする (default: false)。万一クラッシュしても safety screen
    # から `hyprctl dispatch exec hyprlock` で復帰可能になる。
    allow_session_lock_restore = true
}

#############
### INPUT ###
#############

input {
    kb_layout = us
    kb_variant = colemak
    follow_mouse = 1
    sensitivity = 1.0
    repeat_rate = 35
    repeat_delay = 400

    touchpad {
        natural_scroll = false
        tap-to-click = false
        clickfinger_behavior = true
    }
}

device {
    name = epic-mouse-v1
    sensitivity = -0.5
}

###################
### KEYBINDINGS ###
###################

# StarCraft2 Grid-Inspired Layout for Colemak Users
$mainMod = SUPER

# === BASIC APPLICATIONS ===
bind = $mainMod, Return, exec, $terminal
bind = $mainMod SHIFT, Return, exec, [float; size 30% 40%; center] $terminal -e zsh -c "vim ~/memo.md"
bind = $mainMod SHIFT CTRL, Return, exec, [float; size 30% 40%; center;] $terminal -e zsh -c "nvim ~/.note.gpg"
bind = $mainMod SHIFT, q, killactive
bind = $mainMod, d, exec, $menu
bind = $mainMod, w, exec, $browser
bind = $mainMod, s, exec, $terminal -e yazi
bind = $mainMod SHIFT, s, exec, $fileManager

# === UNIFIED LAUNCHER (Raycast/Spotlight-like) ===
bind = $mainMod, space, exec, ~/.local/bin/unified_launcher.sh

bind = $mainMod, a, exec, ~/.local/bin/hypr_perfmodeswitch.sh
bind = $mainMod CTRL, a, exec, ~/.local/bin/hypr_auto_perfmonitor.sh status | xargs -I {} notify-send "Performance Monitor" "{}"

# === SCREEN LOCK ===
bind = $mainMod, l, exec, hyprlock

# === WINDOW OPERATIONS ===
bind = $mainMod, f, fullscreen, 1
bind = $mainMod SHIFT, f, fullscreen
# Alt+M: maximize トグル (tmux 内では tmux 側に吸われて pane zoom、tmux 外なら Hyprland maximize)
bind = ALT, m, fullscreen, 1
bind = $mainMod SHIFT, space, togglefloating
bind = $mainMod, tab, exec, hyprctl dispatch focusurgentorlast
bind = $mainMod, p, exec, hyprctl clients -j | jq -r '.[] | select(.mapped == true) | select(.workspace.id > 0) | "[\(.workspace.id)] \(.class): \(.title // "No Title")"' | wofi --dmenu --prompt="ウィンドウ検索" | cut -d'|' -f1 | xargs -I {} hyprctl dispatch focuswindow "address:{}"
bind = $mainMod, v, layoutmsg, togglesplit

# === WINDOW GROUPING (StarCraft2 Grid-inspired: Group commands in left hand) ===
# Primary group toggle - most used, so put on strong finger
bind = $mainMod, g, togglegroup
bind = $mainMod SHIFT, g, moveoutofgroup
# Group navigation - adjacent to primary toggle for easy sequences
bind = $mainMod, t, changegroupactive, f
bind = $mainMod SHIFT, t, changegroupactive, b

# Add to group (vim directions) - keep these as they work well with vim users
bind = $mainMod CTRL, h, moveintogroup, l
bind = $mainMod CTRL, n, moveintogroup, d
bind = $mainMod CTRL, e, moveintogroup, u
bind = $mainMod CTRL, i, moveintogroup, r

# Add to group (arrows)
bind = $mainMod CTRL, left, moveintogroup, l
bind = $mainMod CTRL, down, moveintogroup, d
bind = $mainMod CTRL, up, moveintogroup, u
bind = $mainMod CTRL, right, moveintogroup, r

# Detach from group (vim directions)
bind = $mainMod CTRL SHIFT, h, moveoutofgroup, l
bind = $mainMod CTRL SHIFT, n, moveoutofgroup, d
bind = $mainMod CTRL SHIFT, e, moveoutofgroup, u
bind = $mainMod CTRL SHIFT, i, moveoutofgroup, r

# Detach from group (arrows)
bind = $mainMod CTRL SHIFT, left, moveoutofgroup
bind = $mainMod CTRL SHIFT, down, moveoutofgroup
bind = $mainMod CTRL SHIFT, up, moveoutofgroup
bind = $mainMod CTRL SHIFT, right, moveoutofgroup

# Moved from f to avoid conflict with file manager
bind = $mainMod ALT, p, exec, hyprctl --batch "dispatch lockactivegroup on; dispatch fullscreen 1; dispatch lockactivegroup off"

# Group workspace movement
bind = $mainMod ALT, 1, exec, hyprctl --batch "dispatch lockactivegroup on; dispatch movetoworkspace 1; dispatch lockactivegroup off"
bind = $mainMod ALT, 2, exec, hyprctl --batch "dispatch lockactivegroup on; dispatch movetoworkspace 2; dispatch lockactivegroup off"
bind = $mainMod ALT, 3, exec, hyprctl --batch "dispatch lockactivegroup on; dispatch movetoworkspace 3; dispatch lockactivegroup off"
bind = $mainMod ALT, 4, exec, hyprctl --batch "dispatch lockactivegroup on; dispatch movetoworkspace 4; dispatch lockactivegroup off"
bind = $mainMod ALT, 5, exec, hyprctl --batch "dispatch lockactivegroup on; dispatch movetoworkspace 5; dispatch lockactivegroup off"

# === WINDOW FOCUS (VIM) ===
bind = $mainMod, h, movefocus, l
bind = $mainMod, n, movefocus, d
bind = $mainMod, e, movefocus, u
bind = $mainMod, i, movefocus, r

# === WINDOW FOCUS (ARROWS) ===
bind = $mainMod, left, movefocus, l
bind = $mainMod, right, movefocus, r
bind = $mainMod, up, movefocus, u
bind = $mainMod, down, movefocus, d

# === WINDOW MOVEMENT (VIM) ===
bind = $mainMod SHIFT, h, movewindow, l
bind = $mainMod SHIFT, n, movewindow, d
bind = $mainMod SHIFT, e, movewindow, u
bind = $mainMod SHIFT, i, movewindow, r

# === WINDOW MOVEMENT (ARROWS) ===
bind = $mainMod SHIFT, left, movewindow, l
bind = $mainMod SHIFT, down, movewindow, d
bind = $mainMod SHIFT, up, movewindow, u
bind = $mainMod SHIFT, right, movewindow, r

# === WORKSPACES ===
bind = $mainMod, 1, workspace, 1
bind = $mainMod, 2, workspace, 2
bind = $mainMod, 3, workspace, 3
bind = $mainMod, 4, workspace, 4
bind = $mainMod, 5, workspace, 5
bind = $mainMod, 6, workspace, 6
bind = $mainMod, 7, workspace, 7
bind = $mainMod, 8, workspace, 8
bind = $mainMod, 9, workspace, 9
bind = $mainMod, 0, workspace, 10

# === MOVE TO WORKSPACES ===
bind = $mainMod SHIFT, 1, movetoworkspace, 1
bind = $mainMod SHIFT, 2, movetoworkspace, 2
bind = $mainMod SHIFT, 3, movetoworkspace, 3
bind = $mainMod SHIFT, 4, movetoworkspace, 4
bind = $mainMod SHIFT, 5, movetoworkspace, 5
bind = $mainMod SHIFT, 6, movetoworkspace, 6
bind = $mainMod SHIFT, 7, movetoworkspace, 7
bind = $mainMod SHIFT, 8, movetoworkspace, 8
bind = $mainMod SHIFT, 9, movetoworkspace, 9
bind = $mainMod SHIFT, 0, movetoworkspace, 10

# === SCRATCHPAD ===
bind = $mainMod, grave, togglespecialworkspace, magic
bind = $mainMod SHIFT, grave, movetoworkspace, special:magic
bind = $mainMod SHIFT, minus, togglespecialworkspace, desktop

# === MOUSE OPERATIONS ===
bindm = $mainMod, mouse:272, movewindow
bindm = $mainMod, mouse:273, resizewindow

# === MULTIMEDIA KEYS (swayosd-client で OSD 付き) ===
bindel = , XF86AudioRaiseVolume, exec, swayosd-client --output-volume raise
bindel = , XF86AudioLowerVolume, exec, swayosd-client --output-volume lower
bindel = , XF86AudioMute, exec, swayosd-client --output-volume mute-toggle
bindel = , XF86AudioMicMute, exec, swayosd-client --input-volume mute-toggle
bindel = , XF86MonBrightnessUp, exec, swayosd-client --brightness raise
bindel = , XF86MonBrightnessDown, exec, swayosd-client --brightness lower

# === MEDIA CONTROLS ===
bindl = , XF86AudioNext, exec, playerctl next
bindl = , XF86AudioPause, exec, playerctl play-pause
bindl = , XF86AudioPlay, exec, playerctl play-pause
bindl = , XF86AudioPrev, exec, playerctl previous

# === LAPTOP LID ===
bindl = , switch:on:Lid Switch, exec, hyprctl keyword monitor "eDP-1, disable"
{{- if eq .chezmoi.hostname "fp7-e14" }}
# 蓋開け: 内蔵パネルの scale は monitors.conf と一致させ 1.25。
# 素早い開閉のチャタリングや amdgpu PSR スタックでパネルが黒落ちするため、再有効化後に dpms on を明示する
# (fp7-e14 は hypridle 不使用で DPMS 復帰の保険が無いため必須)。
bindl = , switch:off:Lid Switch, exec, hyprctl keyword monitor "eDP-1, preferred, auto, 1.25" && hyprctl dispatch dpms on
{{- else }}
bindl = , switch:off:Lid Switch, exec, hyprctl keyword monitor "eDP-1, preferred, auto, 1" && hyprctl dispatch dpms on
{{- end }}

# === CLIPBOARD MANAGEMENT ===
bind = CTRL $mainMod, V, exec, cliphist list | wofi --dmenu --prompt="📋 選択→貼り付け" | cliphist decode | wl-copy && sleep 0.1 && wtype -M ctrl v

# === NOTIFICATION CENTER ===
bind = $mainMod, R, exec, swaync-client -t -sw
bind = $mainMod SHIFT, R, exec, ~/.local/bin/claude-notify-focus "$(cat ${XDG_RUNTIME_DIR:-/tmp}/claude-code-notify/last_session 2>/dev/null)" "$(cat ${XDG_RUNTIME_DIR:-/tmp}/claude-code-notify/last_window 2>/dev/null)" "$(cat ${XDG_RUNTIME_DIR:-/tmp}/claude-code-notify/last_pane 2>/dev/null)"

# === SCREENSHOTS (WINDOWS/LINUX STYLE) ===
bind = , Print, exec, grim - | swappy -f -
bind = SHIFT, Print, exec, grim -g "$(slurp)" - | swappy -f -

# === SCREENSHOTS (CORRECTED) ===
bind = $mainMod SHIFT, P, exec, grim - | swappy -f -  
bind = $mainMod CTRL SHIFT, P, exec, grim -g "$(slurp)" - | swappy -f -

# === RENDERING OPTIMIZATION ===
render {
    direct_scanout = false
}
