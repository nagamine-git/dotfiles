-- ソース管理ビュー (VSCode の Source Control 感覚)
vim.keymap.set('n', '<leader>gg', ':DiffviewOpen<CR>', { noremap = true, silent = true, desc = 'ソース管理ビューを開く' })
vim.keymap.set('n', '<leader>gc', ':DiffviewClose<CR>', { noremap = true, silent = true, desc = 'ソース管理ビューを閉じる' })
vim.keymap.set('n', '<leader>gh', function()
  -- 実ファイル上ならそのファイルの履歴、neo-tree 等の特殊バッファ上なら
  -- リポジトリ全体の履歴にフォールバック (% が疑似バッファを指すエラーを回避)
  local f = vim.fn.expand('%:p')
  if vim.bo.buftype == '' and f ~= '' and vim.fn.filereadable(f) == 1 then
    vim.cmd('DiffviewFileHistory %')
  else
    vim.cmd('DiffviewFileHistory')
  end
end, { noremap = true, silent = true, desc = 'このファイルの変更履歴 (特殊バッファではリポジトリ全体)' })
vim.keymap.set('n', '<leader>gH', ':DiffviewFileHistory<CR>', { noremap = true, silent = true, desc = 'リポジトリの変更履歴' })
vim.keymap.set('n', '<M-d>', ':DiffviewOpen<CR>', { noremap = true, silent = true }) -- 従来キーも維持

-- LSP設定 (Neovim 0.12 標準の vim.lsp.config / vim.lsp.enable 方式)
-- nvim-lspconfig はサーバ定義データとして利用。バイナリが入っているサーバだけ有効化するので
-- 未インストール環境でもエラーにならず、後からサーバを入れれば自動で有効になる。
vim.lsp.config('*', {
  capabilities = require('blink.cmp').get_lsp_capabilities(),
})
local lsp_servers = {
  lua_ls = 'lua-language-server',
  gopls = 'gopls',
  rust_analyzer = 'rust-analyzer',
  pyright = 'pyright-langserver',
  ruff = 'ruff',
  ts_ls = 'typescript-language-server',
  bashls = 'bash-language-server',
}
for server, bin in pairs(lsp_servers) do
  if vim.fn.executable(bin) == 1 then
    vim.lsp.enable(server)
  end
end

-- LSP キーマップ (VSCode の定義ジャンプ/参照/リネーム/コードアクション相当)。
-- LspAttach で「LSP が付いたバッファだけ」に設定。( ) 内は対応する VSCode 操作。
vim.api.nvim_create_autocmd('LspAttach', {
  callback = function(ev)
    local function map(mode, keys, fn, desc)
      vim.keymap.set(mode, keys, fn, { buffer = ev.buf, silent = true, desc = desc })
    end
    map('n', 'gd', vim.lsp.buf.definition, '定義へジャンプ (F12)')
    map('n', 'gD', vim.lsp.buf.declaration, '宣言へジャンプ')
    map('n', 'gr', vim.lsp.buf.references, '参照一覧 (Shift+F12)')
    map('n', 'gi', vim.lsp.buf.implementation, '実装へジャンプ')
    map('n', 'gy', vim.lsp.buf.type_definition, '型定義へジャンプ')
    map('n', 'K', vim.lsp.buf.hover, 'ホバー (ドキュメント表示)')
    map('n', '<leader>rn', vim.lsp.buf.rename, 'シンボルをリネーム (F2)')
    map({ 'n', 'v' }, '<leader>ca', vim.lsp.buf.code_action, 'コードアクション (Ctrl+.)')
    map('n', '<leader>e', vim.diagnostic.open_float, '行の診断を表示')
    map('n', '[d', function() vim.diagnostic.jump({ count = -1, float = true }) end, '前の診断へ')
    map('n', ']d', function() vim.diagnostic.jump({ count = 1, float = true }) end, '次の診断へ')
    -- inlay hints (VSCode の型注釈インライン表示)。対応サーバなら自動でオン、<leader>ih で切替。
    if vim.lsp.inlay_hint then
      pcall(vim.lsp.inlay_hint.enable, true, { bufnr = ev.buf })
      map('n', '<leader>ih', function()
        vim.lsp.inlay_hint.enable(
          not vim.lsp.inlay_hint.is_enabled({ bufnr = ev.buf }), { bufnr = ev.buf })
      end, 'インレイヒント切替')
    end
  end,
})

