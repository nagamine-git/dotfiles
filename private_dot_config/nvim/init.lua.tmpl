-- init.lua
vim.loader.enable()

-- 基本設定
vim.opt.encoding = 'utf-8'
vim.opt.number = true
vim.opt.cursorline = true
vim.opt.mouse = 'a'
vim.opt.termguicolors = true
vim.opt.background = 'dark'
vim.opt.splitright = true
vim.opt.autoread = true
