-- gitsigns設定 (行単位の変更表示 + ステージ操作。コミットは tmux ペインの git/Claude Code で)
require('gitsigns').setup({
  on_attach = function(bufnr)
    local gs = require('gitsigns')
    local function map(mode, l, r, desc)
      vim.keymap.set(mode, l, r, { buffer = bufnr, silent = true, desc = desc })
    end
    map('n', ']c', function() gs.nav_hunk('next') end, '次の変更へ')
    map('n', '[c', function() gs.nav_hunk('prev') end, '前の変更へ')
    map('n', '<leader>gs', gs.stage_hunk, 'この hunk をステージ')
    map('n', '<leader>gr', gs.reset_hunk, 'この hunk を破棄')
    map('n', '<leader>gS', gs.stage_buffer, 'ファイル全体をステージ')
    map('n', '<leader>gp', gs.preview_hunk, '変更をインラインプレビュー')
    map('n', '<leader>gb', function() gs.blame_line({ full = true }) end, '行の blame')
  end,
})

