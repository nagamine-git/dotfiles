{
  "env": {
    "PATH": "$(PATH):$(HOME)/.local/bin"
  },
  "apps": [
    {
      "name": "Desktop",
      "prep-cmd": [
        {
          "do": "/home/tsuyoshi/.local/bin/sunshine-stream-hooks.sh on",
          "undo": "/home/tsuyoshi/.local/bin/sunshine-stream-hooks.sh off"
        }
      ],
      "image-path": "desktop.png"
    },
    {
      "name": "Hyprland (virtual display)",
      "prep-cmd": [
        {
          "do": "/home/tsuyoshi/.local/bin/sunshine-stream-hooks.sh on",
          "undo": "/home/tsuyoshi/.local/bin/sunshine-stream-hooks.sh off"
        },
        {
          "do": "/home/tsuyoshi/.local/bin/sunshine-virtual-display.sh on",
          "undo": "/home/tsuyoshi/.local/bin/sunshine-virtual-display.sh off"
        }
      ],
      "image-path": "desktop.png"
    },
    {
      "name": "Terminal (ghostty)",
      "prep-cmd": [
        {
          "do": "/home/tsuyoshi/.local/bin/sunshine-stream-hooks.sh on",
          "undo": "/home/tsuyoshi/.local/bin/sunshine-stream-hooks.sh off"
        }
      ],
      "detached": ["ghostty"],
      "image-path": "terminal.png"
    }
  ]
}
