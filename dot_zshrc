_claude_notify_idle_watch() {
    [ -z "${TMUX_PANE:-}" ] && return 0

    local runtime_dir="${XDG_RUNTIME_DIR:-/tmp}/claude-code-notify"
    mkdir -p "$runtime_dir"
    local key session window pane prompt_file pid_file
    session="$(tmux display-message -p '#{session_name}' 2>/dev/null || true)"
    window="$(tmux display-message -p '#{window_index}' 2>/dev/null || true)"
    pane="$(tmux display-message -p '#{pane_index}' 2>/dev/null || true)"
    key="${session}_${window}_${pane}"
    prompt_file="$runtime_dir/${key}.prompt"
    pid_file="$runtime_dir/${key}.idle.pid"

    tmux capture-pane -p -S -20 > "$prompt_file" 2>/dev/null || true

    (
      sleep 30
      current="$(tmux capture-pane -p -S -20 2>/dev/null || true)"
      before="$(cat "$prompt_file" 2>/dev/null || true)"
      if [ "$current" = "$before" ]; then
        "$HOME/.local/bin/claude-notify" idle30 "入力待ちが30秒続いています" >/dev/null 2>&1 || true
      fi
      rm -f "$prompt_file" "$pid_file"
    ) &!
    echo $! > "$pid_file"
}

cc() {
    if [ -n "${TMUX_PANE:-}" ] && command -v tmux >/dev/null 2>&1; then
        tmux rename-window "claude" 2>/dev/null || true
        printf '\033]0;%s\007' "claude:$(tmux display-message -p '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null || echo unknown)"
    fi

    if _cc_is_pro_available; then
        echo "→ Claude Pro (sonnet)" >&2
        claude --model sonnet "$@"
    elif _cc_is_ollama_model_available "glm-5"; then
        echo "→ Ollama: glm-5:cloud" >&2
        ollama launch claude --model glm-5:cloud "$@"
    elif _cc_is_ollama_model_available "$_CC_LOCAL_MODEL"; then
        echo "→ Ollama local: $_CC_LOCAL_MODEL" >&2
        ollama launch claude --model "$_CC_LOCAL_MODEL" "$@"
    else
        echo "[cc] 利用可能なバックエンドが見つかりません:" >&2
        echo "  1. Claude Pro: claude auth login" >&2
        echo "  2. Ollama cloud: ollama pull glm-5" >&2
        echo "  3. Ollama local: ollama pull glm-4.7-flash && ollama create $_CC_LOCAL_MODEL" >&2
        return 1
    fi

    _claude_notify_idle_watch
}

# セキュリティ/更新チェックの起動時表示 (Arch のみ)
# 実体は ~/.local/bin/security-update-check.sh が state ファイルへ書く。zsh は「読むだけ」+
# stat 数回で済ませ起動を遅くしない。重い arch-audit/checkupdates は cache が 24h 超のとき
# だけ裏で回す (&! でプロンプト非ブロック、結果は次回シェルに反映)。
# 警告は 3 系統: ①修正版が出た CVE(即/赤) ②最終更新から14日(soft/黄) ③30日(keyringリスク/赤)。
if [[ "$OSTYPE" != darwin* ]] && command -v security-update-check.sh >/dev/null 2>&1; then
  () {
    local state="${XDG_STATE_HOME:-$HOME/.local/state}/security-update-check/status"
    local pacdb=/var/lib/pacman/local
    local max_age=$((24*3600))    # 24h でキャッシュ再生成
    local stale1=$((14*86400))    # 14日: そろそろ更新 (soft)
    local stale2=$((30*86400))    # 30日: keyring 古化リスク帯 (loud)
    zmodload zsh/datetime 2>/dev/null   # EPOCHSECONDS
    zmodload zsh/stat 2>/dev/null       # zstat

    local now=$EPOCHSECONDS cache_mtime=0 db_mtime=0
    [[ -e $state ]] && cache_mtime=$(zstat +mtime "$state" 2>/dev/null)
    [[ -e $pacdb ]] && db_mtime=$(zstat +mtime "$pacdb" 2>/dev/null)

    # キャッシュがあり、かつ前回チェック後にパッケージ変更が無い (= 内容が信頼できる) ときだけ表示。
    # 直後に pacman -Syu した場合は db_mtime > cache_mtime となり、古い値で誤警告しない。
    if [[ -s $state && $db_mtime -le $cache_mtime ]]; then
      local first; read -r first < "$state"
      local vuln=0 last_up=0 f
      for f in ${(s: :)first}; do
        case $f in
          vuln=*)         vuln=${f#vuln=} ;;
          last_upgrade=*) last_up=${f#last_upgrade=} ;;
        esac
      done
      # ① 修正版が出た CVE は最優先で常に警告
      if [[ $vuln -gt 0 ]]; then
        print -P "%F{red}%B⚠ 要対応CVE ${vuln}件%b%f → %F{yellow}sudo pacman -Syu%f  (詳細: cat ${state/#$HOME/~})"
      fi
      # ②③ 最終更新からの経過で滞留警告
      if [[ $last_up -gt 0 ]]; then
        local age=$(( now - last_up )) days=$(( (now - last_up) / 86400 ))
        if   (( age >= stale2 )); then
          print -P "%F{red}⚠ 最終更新から ${days}日%f keyring 古化リスク → %F{yellow}sudo pacman -Sy archlinux-keyring && sudo pacman -Su%f"
        elif (( age >= stale1 )); then
          print -P "%F{yellow}● 最終更新から ${days}日%f そろそろ → %F{yellow}sudo pacman -Syu%f"
        fi
      fi
    fi

    # 未生成 / パッケージ変更後 / 24h 超 なら裏で再チェック (結果は次回起動に反映)
    if [[ ! -s $state || $db_mtime -gt $cache_mtime || $(( now - cache_mtime )) -gt $max_age ]]; then
      ( security-update-check.sh >/dev/null 2>&1 ) &!
    fi
  }
fi

