    # Check if tmux server is running
    if ! tmux list-sessions >/dev/null 2>&1; then
        is_first_session=true
    fi
    if [ -n "$TMUX" ]; then
        tmux new-session -d -s "$name" -c "$PWD"
        tmux switch-client -t "$name"
