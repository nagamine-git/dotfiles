{{- $c := .theme.colors -}}
{{- if eq .chezmoi.os "darwin" -}}
{{- $c = .theme.colors_darwin -}}
{{- else if eq .chezmoi.hostname "fp7-e14" -}}
{{- $c = .theme.colors_catppuccin -}}
{{- end -}}
set -g mouse on

# ghostty/foot 向けの端末能力宣言
set -g default-terminal "tmux-256color"
set -as terminal-features ',*:RGB'
set -as terminal-features ',*:usstyle'
set -as terminal-features ',*:clipboard'
set -as terminal-features ',*:extkeys'
set -s extended-keys on
set -s escape-time 10
set -g history-limit 50000

# kitty graphics protocol（image.nvim / diagram.nvim で mermaid 等の画像表示）
set -g allow-passthrough all
set -g focus-events on
set -ga update-environment TERM
set -ga update-environment TERM_PROGRAM

setw -g mode-keys vi
bind -T copy-mode-vi v send -X begin-selection
bind -T copy-mode-vi y send -X copy-selection-and-cancel

unbind C-b

# C-aにバインド
set-option -g prefix C-t
bind-key C-t send-keys C-t
# コピーモードはvimに似せる
unbind [
bind-key v copy-mode


# painサイズ切り替え
bind-key -n M-Left resize-pane -L 3
bind-key -n M-Right resize-pane -R 3
bind-key -n M-Up resize-pane -U 3
bind-key -n M-Down resize-pane -D 3

bind-key -n M-Tab switch-client -l

set -g @plugin 'tmux-plugins/tpm'
set -g @tmux_power_theme '#{{ $c.primary.hex }}'
set -g @tmux_power_g0 "#{{ $c.bg_dark.hex }}"
set -g @tmux_power_g1 "#{{ $c.bg_medium.hex }}"
set -g @tmux_power_g2 "#{{ $c.bg_light.hex }}"
set -g @tmux_power_g3 "#{{ $c.surface.hex }}"
set -g @tmux_power_g4 "#{{ $c.text_dim.hex }}"
set -g @tmux_power_date_format '%y.%m.%d'
set -g @tmux_power_time_format '%R'
set -g status-style 'bg=#{{ $c.bg_dark.hex }},fg=#{{ $c.text.hex }}'
set -g message-style 'bg=#{{ $c.primary.hex }},fg=#{{ $c.bg_dark.hex }}'
set -g message-command-style 'bg=#{{ $c.accent.hex }},fg=#{{ $c.bg_dark.hex }}'
set -g pane-border-style 'fg=#{{ $c.bg_light.hex }}'
set -g pane-active-border-style 'fg=#{{ $c.primary.hex }}'

# copy-mode の選択を強調 (公式 issue #1500: モード表示が弱いUX欠落への対応)
set -g mode-style 'fg=#{{ $c.bg_dark.hex }},bg=#{{ $c.primary.hex }},bold'

# アクティブ pane を「境界色 + 背景明暗」の二重手がかりで識別 (Gestalt figure-ground)。
# 非アクティブを僅かに暗く。色差だけで十分 or 低スペック機で重い場合はこの2行を消せば戻る。
set -g window-style 'fg=default,bg=#{{ $c.bg_dark.hex }}'
set -g window-active-style 'fg=default,bg=#{{ $c.bg_medium.hex }}'
set -g @plugin 'wfxr/tmux-power'
set -g @plugin 'tmux-plugins/tmux-resurrect'
# ペイン画面のテキストも保存（claude code 等の表示を復元時に再描画）
set -g @resurrect-capture-pane-contents 'on'
set -g @plugin 'tmux-plugins/tmux-continuum'
# 自動保存（15分間隔）＋ tmux 起動時に自動復元
set -g @continuum-restore 'on'
set -g @plugin 'sainnhe/tmux-fzf'
set -g @tmux-fzf-launch-key 'f'
set -g @plugin '2kabhishek/tmux-tilit'
set -g @plugin 'long-910/claude-tmux-status'
set -g @claude-tmux-auto-status "false"
run '~/.tmux/plugins/tpm/tpm'
set -ag status-right "#[fg=#{{ $c.accent.hex }},bg=#{{ $c.primary.hex }}]#[fg=#{{ $c.bg_dark.hex }},bg=#{{ $c.accent.hex }},bold] ☁ #(claude-usage-colored)#[fg=#{{ $c.text.hex }},bg=#{{ $c.bg_dark.hex }}]"


# Override tmux-tilit's extrakto binding (extrakto not installed)
bind-key -n M-f run "tmux split-window -l 12 'zsh -ci tmux_fzf_window'"

# Override tmux-tilit's M-m (main-vertical layout) → アクティブ pane の最大化トグル
bind-key -n M-m resize-pane -Z \; display-message "zoom: #{?window_zoomed_flag,on,off}"

# main-vertical を使うときの幅。4K (3840px) で main/side = 1920/1920px ≒ 160chars 等分。
set -g main-pane-width "50%"

# 動的レイアウトモード: デフォ ON。pane 数で main-vertical (≤3) / tiled (≥4) を自動切替。
#   N≤3: main-vertical (Baudisch CHI 2002 — focus+context は等価より 21-36% 高速)
#   N≥4: tiled         (Cowan 2001 — STM ~4 chunks 超で focus+context が破綻、格子の方が認知負荷低)
set-option -g @layout_mode "on"

# Alt+Enter: 純粋な split。direction は気にしない (どうせ hook が再配置する)。
bind-key -n M-Enter split-window -v -c "#{pane_current_path}"

# 動的レイアウトモードのトグル (prefix C-t → M-Enter)。
#   on  → off: hook 抑止 → tmux 自由配置で固定
#   off → on : 即 pane 数に応じて再配置 + 以降 hook で切替
bind-key M-Enter run-shell '\
  if [ "$(tmux display-message -p "#{@layout_mode}")" = "on" ]; then \
    tmux set-window-option @layout_mode "off"; \
    tmux display-message "layout-mode: off (free)"; \
  else \
    tmux set-window-option @layout_mode "on"; \
    if [ "$(tmux display-message -p "#{window_panes}")" -le 3 ]; then \
      tmux select-layout main-vertical; \
    else \
      tmux select-layout tiled; \
    fi; \
    tmux display-message "layout-mode: on (main-vertical / tiled auto)"; \
  fi \
'

set-hook -g after-split-window 'if-shell -F "#{==:#{@layout_mode},on}" "if-shell -F \"#{<=:#{window_panes},3}\" \"select-layout main-vertical\" \"select-layout tiled\""'
set-hook -g pane-exited        'if-shell -F "#{==:#{@layout_mode},on}" "if-shell -F \"#{<=:#{window_panes},3}\" \"select-layout main-vertical\" \"select-layout tiled\""'
set-hook -g after-kill-pane    'if-shell -F "#{==:#{@layout_mode},on}" "if-shell -F \"#{<=:#{window_panes},3}\" \"select-layout main-vertical\" \"select-layout tiled\""'
set-hook -g client-resized     'if-shell -F "#{==:#{@layout_mode},on}" "if-shell -F \"#{<=:#{window_panes},3}\" \"select-layout main-vertical\" \"select-layout tiled\""'
