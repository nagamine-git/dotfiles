{{- $c := .theme.colors -}}
{{- if eq .chezmoi.os "darwin" -}}
{{- $c = .theme.colors_darwin -}}
{{- end -}}
set -g mouse on

# ghostty/foot 向けの端末能力宣言
set -g default-terminal "tmux-256color"
set -as terminal-features ',*:RGB'
set -as terminal-features ',*:usstyle'
set -as terminal-features ',*:clipboard'
set -as terminal-features ',*:extkeys'
set -s extended-keys on
set -s escape-time 10
set -g history-limit 50000

# kitty graphics protocol（image.nvim / diagram.nvim で mermaid 等の画像表示）
set -g allow-passthrough all
set -g focus-events on
set -ga update-environment TERM
set -ga update-environment TERM_PROGRAM

setw -g mode-keys vi
bind -T copy-mode-vi v send -X begin-selection
bind -T copy-mode-vi y send -X copy-selection-and-cancel

unbind C-b

# C-aにバインド
set-option -g prefix C-t
bind-key C-t send-keys C-t
# コピーモードはvimに似せる
unbind [
bind-key v copy-mode


# painサイズ切り替え
bind-key -n M-Left resize-pane -L 3
bind-key -n M-Right resize-pane -R 3
bind-key -n M-Up resize-pane -U 3
bind-key -n M-Down resize-pane -D 3

bind-key -n M-Tab switch-client -l

set -g @plugin 'tmux-plugins/tpm'
set -g @tmux_power_theme '#{{ $c.primary.hex }}'
set -g @tmux_power_g0 "#{{ $c.bg_dark.hex }}"
set -g @tmux_power_g1 "#{{ $c.bg_medium.hex }}"
set -g @tmux_power_g2 "#{{ $c.bg_light.hex }}"
set -g @tmux_power_g3 "#{{ $c.surface.hex }}"
set -g @tmux_power_g4 "#{{ $c.text_dim.hex }}"
set -g @tmux_power_date_format '%y.%m.%d'
set -g @tmux_power_time_format '%R'
set -g status-style 'bg=#{{ $c.bg_dark.hex }},fg=#{{ $c.text.hex }}'
set -g message-style 'bg=#{{ $c.primary.hex }},fg=#{{ $c.bg_dark.hex }}'
set -g message-command-style 'bg=#{{ $c.accent.hex }},fg=#{{ $c.bg_dark.hex }}'
set -g pane-border-style 'fg=#{{ $c.bg_light.hex }}'
set -g pane-active-border-style 'fg=#{{ $c.primary.hex }}'
set -g @plugin 'wfxr/tmux-power'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'sainnhe/tmux-fzf'
set -g @tmux-fzf-launch-key 'f'
set -g @plugin '2kabhishek/tmux-tilit'
set -g @plugin 'long-910/claude-tmux-status'
set -g @claude-tmux-auto-status "false"
run '~/.tmux/plugins/tpm/tpm'
set -ag status-right "#[fg=#{{ $c.accent.hex }},bg=#{{ $c.primary.hex }}]#[fg=#{{ $c.bg_dark.hex }},bg=#{{ $c.accent.hex }},bold] ☁ #(claude-usage-colored)#[fg=#{{ $c.text.hex }},bg=#{{ $c.bg_dark.hex }}]"


# Override tmux-tilit's extrakto binding (extrakto not installed)
bind-key -n M-f run "tmux split-window -l 12 'zsh -ci tmux_fzf_window'"

# Alt+Enter: main-vertical レイアウトでサイドに追加（メイン60%）
set -g main-pane-width "60%"
bind-key -n M-Enter split-window -h -c "#{pane_current_path}" \; set-window-option @layout_mode main-vertical \; select-layout main-vertical

# main-vertical フラグが立っているウィンドウでは、ペイン変化後にレイアウトを再適用
set-hook -g after-split-window 'if-shell -F "#{==:#{@layout_mode},main-vertical}" "select-layout main-vertical"'
set-hook -g pane-exited        'if-shell -F "#{==:#{@layout_mode},main-vertical}" "select-layout main-vertical"'
set-hook -g after-kill-pane    'if-shell -F "#{==:#{@layout_mode},main-vertical}" "select-layout main-vertical"'
set-hook -g client-resized     'if-shell -F "#{==:#{@layout_mode},main-vertical}" "select-layout main-vertical"'

# レイアウト解除（元の自由配置に戻したい時）
bind-key M-Enter set-window-option -u @layout_mode
